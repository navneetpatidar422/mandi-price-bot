# ===================================================
# सही Mandi Bot - Environment Variables
# ===================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===================================================

# Google Gemini API Key (free tier available)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY= YOUR_API KEY

# Bot Name (you can customize)
BOT_NAME=सही Mandi

# Developer Name
DEVELOPER_NAME=Navneet Patidar

# Cache duration in minutes (default: 30)
CACHE_DURATION_MINUTES=30

# Maximum retries for Agmarknet requests
MAX_RETRIES=3
